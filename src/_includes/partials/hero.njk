<header class="hero">
  {% if site.hero.videoUrl %}
  <video class="hero__video" autoplay muted loop playsinline poster="{{ site.hero.posterUrl }}">
    {% if site.hero.mobileVideoUrl %}
    <source src="{{ site.hero.mobileVideoUrl }}" type="video/mp4" media="(max-width: 720px) and (orientation: portrait)">
    {% endif %}
    <source src="{{ site.hero.videoUrl }}" type="video/mp4">
  </video>
  {% else %}
  <div class="hero__video hero__video--placeholder" aria-hidden="true"></div>
  {% endif %}

  <div class="hero__vignette" aria-hidden="true"></div>

  <div class="hero__content">
    <h1 class="visually-hidden">{{ site.title }}</h1>
    <p class="hero__status" aria-label="Development status">In early development</p>
    <div class="hero__ctas">
      <a class="btn-wire" href="{{ site.social.steamWishlist }}&utm_content=hero" rel="noopener">Wishlist on Steam</a>
      <a class="btn-wire" href="{{ site.social.discordInvite }}" rel="noopener">Join the Discord</a>
      <a class="btn-wire" href="/devlog/">Read the Devlogs</a>
    </div>
    <a class="hero__scroll" href="#pitch" aria-label="Scroll to features">▼</a>
  </div>
</header>
