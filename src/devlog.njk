---
layout: layouts/base.njk
title: Devlog
description: "Building SYNTHERION in public — origins stories, in-game dev tools, and ongoing work."
permalink: /devlog/
---

{% include "partials/site-header.njk" %}

<main class="devlog-page">
  <header class="devlog-page__header">
    <h1 class="section__heading">Transmissions</h1>

    {% set firstPost = collections.posts | last %}
    {% if firstPost %}
    <p class="devlog-page__starthere">
      New here? <a href="{{ firstPost.url }}">Start at the beginning →</a>
    </p>
    {% endif %}

    <nav class="devlog-page__filters" aria-label="Filter by type">
      <a class="devlog-page__filter devlog-page__filter--all" href="#all" data-filter="all">All</a>
      <a class="devlog-page__filter devlog-page__filter--origins" href="#origins" data-filter="origins">Origins</a>
      <a class="devlog-page__filter devlog-page__filter--tools" href="#tools" data-filter="tools">Tools</a>
      <a class="devlog-page__filter devlog-page__filter--devlog" href="#devlog" data-filter="devlog">Devlog</a>
    </nav>
  </header>

  <div class="post-grid">
    {% for post in collections.posts %}
      {% set post = post %}
      {% set types = post.data.postTypes if post.data.postTypes else [post.data.postType] %}
      <div class="post-grid__item" data-types="{{ types | join(' ') }}">
        {% include "partials/post-card.njk" %}
      </div>
    {% endfor %}
  </div>

  {% if collections.posts.length === 0 %}
  <p class="devlog-page__empty">No transmissions yet. Check back soon.</p>
  {% endif %}
</main>

<script>
(function() {
  const filters = document.querySelectorAll(".devlog-page__filter");
  const items = document.querySelectorAll(".post-grid__item");
  function applyFilter(name) {
    filters.forEach(f => f.classList.toggle("is-active", f.dataset.filter === name));
    items.forEach(el => {
      const types = (el.dataset.types || "").split(/\s+/).filter(Boolean);
      el.style.display = (name === "all" || types.includes(name)) ? "" : "none";
    });
  }
  filters.forEach(f => {
    f.addEventListener("click", (e) => { e.preventDefault(); applyFilter(f.dataset.filter); history.replaceState(null,"",f.getAttribute("href")); });
  });
  // Initialize from hash if present
  const initial = (location.hash || "#all").slice(1);
  applyFilter(["all","origins","tools","devlog"].includes(initial) ? initial : "all");
})();
</script>
