{% if site.buttondown.formAction %}
<form action="{{ site.buttondown.formAction }}"
      method="post"
      target="popupwindow"
      onsubmit="window.open('{{ site.buttondown.formAction }}', 'popupwindow')"
      class="newsletter">
  <label for="bd-email" class="newsletter__label">Stay in the loop</label>
  <p class="newsletter__sub">Devlog updates, no spam. Unsubscribe whenever.</p>
  <div class="newsletter__row">
    <input type="email" name="email" id="bd-email" placeholder="you@domain.com" required class="newsletter__input">
    <button type="submit" class="newsletter__btn">Subscribe →</button>
  </div>
  <input type="hidden" value="1" name="embed">
</form>
{% else %}
<div class="newsletter newsletter--placeholder">
  <p class="newsletter__label">Stay in the loop</p>
  <p class="newsletter__sub">Mailing list signup coming soon.</p>
</div>
{% endif %}
